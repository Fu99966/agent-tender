# mock keeps the demo deterministic and requires no wallet.
# live invokes the installed Kite Agent Passport CLI.
KITE_MODE=mock
PORT=8787

# Optional on Windows when kpass is not available on PATH.
# KPASS_BIN=C:\Users\YOUR_NAME\.kpass\bin\kpass.exe

# Required only in live mode. Use a paid x402/MPP endpoint discovered by ksearch.
KITE_SUPPLIER_URL=https://parallelmpp.dev/api/search
KITE_SUPPLIER_METHOD=POST
KITE_SUPPLIER_BODY={"query":"Compare Base, Arbitrum and Optimism across TVL momentum, fee revenue and protocol risk"}

